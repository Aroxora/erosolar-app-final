rules_version = '2';

// Erosolar chat history.
// Each user can only ever touch data under their own /users/{uid} subtree.
// Conversation metadata is client-managed; individual messages are written
// exclusively by the backend (the Admin SDK bypasses these rules), so a
// client can read its own history but can never forge or tamper with it.
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function owner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    match /users/{uid} {
      allow read: if owner(uid);

      // Owner may write ONLY their own customInstructions field (<= 2000 chars).
      // Everything else on the user doc (the backend-curated profile, etc.) stays
      // backend-only — the Admin SDK bypasses these rules.
      allow create: if owner(uid)
        && request.resource.data.keys().hasOnly(['customInstructions'])
        && request.resource.data.customInstructions is string
        && request.resource.data.customInstructions.size() <= 2000;
      allow update: if owner(uid)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['customInstructions'])
        && request.resource.data.customInstructions is string
        && request.resource.data.customInstructions.size() <= 2000;

      // Long-term memory: written only by the backend (Admin SDK), but the owner
      // may read and delete their own memories (the in-app memory manager).
      match /memories/{mid} {
        allow read, delete: if owner(uid);
        allow create, update: if false;
      }

      // Uploaded-document registry: backend-created; owner may list and delete.
      match /documents/{did} {
        allow read, delete: if owner(uid);
        allow create, update: if false;
      }

      match /conversations/{cid} {
        allow read, create, update, delete: if owner(uid);

        match /messages/{mid} {
          allow read: if owner(uid);
          allow write: if false; // backend-only (Admin SDK)
        }
      }
    }
  }
}
